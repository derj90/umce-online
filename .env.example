# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.udfv.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# App URL (used in email notifications)
NEXT_PUBLIC_APP_URL=https://umce.online

# Moodle API (required for course generation)
MOODLE_VIRTUAL_URL=https://virtual.umce.cl
MOODLE_VIRTUAL_TOKEN=your_moodle_token_here

# SMTP / Brevo (required for email notifications)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_user
SMTP_PASS=your_brevo_password
SMTP_FROM=noreply@udfv.cloud
