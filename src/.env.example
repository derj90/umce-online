# Server
PORT=3000
BASE_URL=https://umce.online

# Google OAuth (restricted to @umce.cl)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Moodle platforms (5 instances)
MOODLE_EVIRTUAL_URL=https://evirtual.umce.cl
MOODLE_EVIRTUAL_TOKEN=
MOODLE_PRACTICA_URL=https://evirtual-practica.umce.cl
MOODLE_PRACTICA_TOKEN=
MOODLE_VIRTUAL_URL=https://virtual.umce.cl
MOODLE_VIRTUAL_TOKEN=
MOODLE_PREGRADO_URL=https://evirtual-pregrado.umce.cl
MOODLE_PREGRADO_TOKEN=
MOODLE_POSTGRADO_URL=https://evirtual-postgrado.umce.cl
MOODLE_POSTGRADO_TOKEN=

# Editor emails (comma-separated, can create/edit content)
EDITOR_EMAILS=

# Supabase self-hosted
SUPABASE_URL=https://supabase.udfv.cloud
SUPABASE_SERVICE_KEY=

# Google Drive API (for PIAC reading — udfv@ OAuth)
# Falls back to GOOGLE_CLIENT_ID/SECRET if not set
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Open Badges 3.0 — Ed25519 keypair for signing Verifiable Credentials
# Generate with: node -e "const kp=require('crypto').generateKeyPairSync('ed25519'); console.log('BADGE_PRIVATE_KEY='+kp.privateKey.export({type:'pkcs8',format:'der'}).toString('base64')); console.log('BADGE_PUBLIC_KEY='+kp.publicKey.export({type:'spki',format:'der'}).toString('base64'))"
BADGE_PRIVATE_KEY=
BADGE_PUBLIC_KEY=
